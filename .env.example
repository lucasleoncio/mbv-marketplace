# === MBV Marketplace — variáveis de ambiente ===
# O DEMO funciona SEM nada disto (modo demonstração). Para o GO-LIVE, preencha
# o que precisar e defina MBV_DEMO_MODE=false. No Render: Settings → Environment.
# Copie para ".env" se for rodar localmente.

# --- Núcleo ---
# PORT=4000
# NODE_ENV=production
APP_URL=https://mbv-marketplace.onrender.com

# Go-live: bloqueia pagamentos simulados e EXIGE segredo/chaves. (demo = não definir ou true)
MBV_DEMO_MODE=true

# Segredo do login — OBRIGATÓRIO no go-live.
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# CORS — origens permitidas (separadas por vírgula). Já tem um padrão sensato.
# ALLOWED_ORIGINS=https://mbv-marketplace.onrender.com,https://movimentobrasilverde.com

# --- Banco de dados / persistência ---
# ESCOLHIDO (08/07/2026): PlanetScale Postgres, plano PS-5 (US$ 5/mês, nó único).
# Crie o banco em planetscale.com (mesma região do Render), copie a connection string
# do painel e defina abaixo. O app usa Postgres quando DATABASE_URL existir; sem ela,
# continua no SQLite (demo/local). A migração do código é a Leva 9 do plano do comitê.
# DATABASE_URL=postgres://usuario:senha@host.psdb.cloud/mbv?sslmode=require
#
# Alternativa simples (sem Postgres): disco do Render (plano pago) e apontar as pastas:
# MBV_DATA_DIR=/var/data
# MBV_UPLOAD_DIR=/var/data/uploads

# --- Mercado Pago (cartão + Pix via Checkout Pro) ---
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
# Configure o webhook no painel do MP apontando para: {APP_URL}/api/webhooks/mercadopago

# --- E-mail (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=MBV — Movimento Brasil Verde <no-reply@movimentobrasilverde.com>

# --- Google Analytics (opcional) ---
GA_ID=

# --- Pagamento on-chain do NTR (Polygon) — ver BLOCKCHAIN.md ---
# Sem NTR_CONTRACT + STORE_WALLET, o pagamento em NTR fica simulado (demo).
# CHAIN_ID=137
# CHAIN_NAME=Polygon
# RPC_URL=https://polygon-rpc.com
# EXPLORER_URL=https://polygonscan.com
# NATIVE_SYMBOL=POL
NTR_CONTRACT=
STORE_WALLET=
# NTR_DECIMALS=18
# MIN_CONFIRMATIONS=3
# RATE_BRL_PER_NTR=9.36

# --- Carrinho abandonado (e-mail disparado por um cron externo) ---
# Chave para chamar GET {APP_URL}/api/jobs/abandoned-cart?key=ESTA_CHAVE
# (agende em um serviço como cron-job.org, ex.: a cada 6 horas)
JOBS_SECRET=

# --- Proteção de margem (opcional) ---
# Teto do desconto total (cupom + NTR). 1 = sem teto. Ex.: 0.15 = máximo 15%.
# MAX_DISCOUNT_PCT=1
